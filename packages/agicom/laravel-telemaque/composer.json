{
    "name": "agicom/laravel-telemaque",
    "version": "1.5.0",
    "description": "Easily retrieve Telemaque Data",
    "keywords": [
        "agicom",
        "laravel",
        "laravel-telemaque"
    ],
    "homepage": "https://github.com/agicom/laravel-telemaque",
    "license": "MIT",
    "authors": [
        {
            "name": "bnzo",
            "email": "17174973+bnzo@users.noreply.github.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "saloonphp/laravel-plugin": "^4.0",
        "saloonphp/pagination-plugin": "^2.0",
        "spatie/laravel-package-tools": "^1.14.0",
        "wendelladriel/laravel-validated-dto": "^3.0|^4.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.0|^3.0",
        "laravel/pint": "^1.0",
        "laravel/tinker": "^2.8|^3.0",
        "nunomaduro/collision": "^7.0|^8.0",
        "orchestra/canvas": "^8.0|^9.0|^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0|^3.0|^4.0",
        "pestphp/pest-plugin-arch": "^2.0|^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0",
        "phpstan/extension-installer": "^1.1",
        "phpstan/phpstan-deprecation-rules": "^1.0|^2.0",
        "phpstan/phpstan-phpunit": "^1.0|^2.0",
        "rector/rector": "^1.0|^2.0",
        "phpstan/phpstan": "^1.0|^2.0",
        "spatie/laravel-ray": "^1.32"
    },
    "autoload": {
        "psr-4": {
            "Agicom\\Telemaque\\": "src/",
            "Agicom\\Telemaque\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Agicom\\Telemaque\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Agicom\\Telemaque\\TelemaqueServiceProvider"
            ],
            "aliases": {
                "Telemaque": "Agicom\\Telemaque\\Facades\\Telemaque"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}