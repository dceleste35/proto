{
    "name": "agicom/laravel-sweepbright",
    "version": "2.0.1",
    "description": "Sweepbright Api wrapper (copie locale patchée : contrainte illuminate élargie à Laravel 13)",
    "keywords": [
        "agicom",
        "laravel",
        "laravel-sweepbright"
    ],
    "homepage": "https://github.com/agicom/laravel-sweepbright",
    "license": "MIT",
    "authors": [
        {
            "name": "agicom",
            "email": "contact@agicom.fr",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^10.0||^11.0||^12.0||^13.0",
        "saloonphp/cache-plugin": "^3.0",
        "saloonphp/laravel-plugin": "^4.0",
        "saloonphp/saloon": "^4.0",
        "spatie/laravel-data": "^4.18",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8||^7.0",
        "larastan/larastan": "^3.0||^2.0",
        "orchestra/testbench": "^10.0.0||^9.0.0||^8.0.0",
        "pestphp/pest": "^4.0||^3.0",
        "pestphp/pest-plugin-arch": "^4.0||^3.0",
        "pestphp/pest-plugin-laravel": "^4.0||^3.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0||^1.0",
        "spatie/laravel-ray": "^1.35"
    },
    "autoload": {
        "psr-4": {
            "Agicom\\Sweepbright\\": "src/",
            "Agicom\\Sweepbright\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Agicom\\Sweepbright\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Agicom\\Sweepbright\\SweepbrightServiceProvider"
            ],
            "aliases": {
                "Sweepbright": "Agicom\\Sweepbright\\Facades\\Sweepbright"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
